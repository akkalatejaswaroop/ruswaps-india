# ===========================================
# RUSSWAPS WEB - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in the values
# For Netlify/Vercel: Add these in Site Settings > Environment Variables

# ===========================================
# DATABASE CONFIGURATION (Required)
# ===========================================
# Example: postgresql://user:password@host:5432/database?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10&idle_timeout=30
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ruswaps?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10&idle_timeout=30

# Connection Pool Settings (optional - for serverless environments)
# DATABASE_POOL_SIZE=5
# DATABASE_CONNECTION_TIMEOUT=10000
# DATABASE_POOL_TIMEOUT=20

# ===========================================
# JWT CONFIGURATION (Required in production)
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=90d

# ===========================================
# OTP ENCRYPTION (Required in production)
# ===========================================
# AES-256-GCM encryption key for storing OTPs securely
# Generate with: openssl rand -hex 32
OTP_ENCRYPTION_SECRET=your-32-character-minimum-encryption-secret

# ===========================================
# SENTRY ERROR TRACKING (Recommended for production)
# ===========================================
# Get from: https://sentry.io/settings/<org>/projects/<project>/keys/
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ===========================================
# RATE LIMITING - Redis/Upstash (Recommended for production)
# ===========================================
# Option 1: Upstash Redis (Serverless friendly)
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Option 2: Standard Redis
# REDIS_URL=redis://localhost:6379

# ===========================================
# RAZORPAY CONFIGURATION (Required for payments)
# ===========================================
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===========================================
# ONESIGNAL CONFIGURATION (Optional)
# ===========================================
# Get from: https://app.onesignal.com/apps
# ONESIGNAL_APP_ID=your_onesignal_app_id
# ONESIGNAL_API_KEY=your_onesignal_api_key

# ===========================================
# EMAIL CONFIGURATION (Optional)
# ===========================================
# SMTP Settings for sending emails (OTP, notifications)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Ruswaps <noreply@example.com>

# ===========================================
# APPLICATION URL (Required)
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ===========================================
# ADMIN CONFIGURATION (Optional)
# ===========================================
NEXT_PUBLIC_ADMIN_KEY=your-admin-secret-key

# ===========================================
# TRUSTED PROXIES (For production behind load balancer)
# ===========================================
# TRUSTED_PROXIES=127.0.0.1,::1,10.0.0.0/8

# ===========================================
# NODE ENVIRONMENT
# ===========================================
NODE_ENV=development
