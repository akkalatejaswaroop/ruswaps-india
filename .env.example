# ===========================================
# RUSSWAPS WEB - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in the values
# For Netlify: Add these in Site Settings > Environment Variables

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# PostgreSQL Database URL (required for production)
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ruswaps

# Alternative database connection (optional)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ruswaps
# DB_USER=postgres
# DB_PASSWORD=your_password

# ===========================================
# JWT CONFIGURATION (Required in production)
# ===========================================
# IMPORTANT: Change this secret in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=30d
JWT_REFRESH_EXPIRES_IN=90d

# ===========================================
# RAZORPAY CONFIGURATION (Server-side only)
# ===========================================
# Get these from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ===========================================
# ONESIGNAL CONFIGURATION (Server-side only)
# ===========================================
# Get these from: https://app.onesignal.com/apps
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_API_KEY=your_onesignal_api_key

# ===========================================
# EMAIL CONFIGURATION (Server-side only)
# ===========================================
# SMTP Settings for sending emails (OTP, notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Ruswaps <your_email@gmail.com>

# ===========================================
# APPLICATION URL (Client-side)
# ===========================================
# These are exposed to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_APP_URL=https://ruswaps.in
NEXT_PUBLIC_API_URL=https://api.ruswaps.in

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
# Admin key for accessing admin panel (exposed to client)
NEXT_PUBLIC_ADMIN_KEY=your-admin-secret-key

# ===========================================
# NODE ENVIRONMENT
# ===========================================
NODE_ENV=development
